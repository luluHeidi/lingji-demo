### 2. 页面状态保持

**从三级返回二级**：
```javascript
async function backToDetailFromForm() {
    const contentArea = document.querySelector('#content');
    
    // 1. 保存当前状态
    const savedState = {
        itemName: currentItemName,
        items: [...currentItems],
        selectedItems: new Set(selectedItems),
        filters: { ...detailFilters }
    };
    
    // 2. 重新加载HTML
    const response = await fetch('./modules/module-name/index.html');
    const htmlContent = await response.text();
    contentArea.innerHTML = htmlContent;
    
    // 3. 确保数据已加载
    if (!moduleData) {
        await loadModuleData();
    }
    
    // 4. 恢复状态
    currentItemName = savedState.itemName;
    currentItems = savedState.items;
    selectedItems = savedState.selectedItems;
    detailFilters = savedState.filters;
    
    // 5. 绑定事件
    bindEvents();
    
    // 6. 显示详情页
    const mainPage = document.querySelector('.main-page');
    const detailPage = document.querySelector('.detail-page');
    
    mainPage.style.display = 'none';
    detailPage.style.display = 'block';
    
    // 7. 更新面包屑
    const breadcrumbElement = document.getElementById('detailItemName');
    if (breadcrumbElement) {
        breadcrumbElement.textContent = currentItemName;
    }
    
    // 8. 绑定详情页事件
    bindDetailEvents();
    
    // 9. 渲染数据（保持筛选状态）
    renderDetailCards();
    
    // 10. 恢复选中状态
    setTimeout(() => {
        document.querySelectorAll('.item-checkbox').forEach(cb => {
            if (selectedItems.has(cb.dataset.id)) {
                cb.checked = true;
            }
        });
        updateBatchActionBar();
        updateSelectAllButton();
    }, 100);
    
    lucide.createIcons();
}
```

**从二级返回一级**：
```javascript
async function backToMainList() {
    const mainPage = document.querySelector('.main-page');
    const detailPage = document.querySelector('.detail-page');
    
    // 如果页面元素存在，直接切换
    if (mainPage && detailPage) {
        detailPage.style.display = 'none';
        mainPage.style.display = 'block';
        
        // 检查内容是否丢失
        const cardsContainer = document.getElementById('cardsContainer');
        if (cardsContainer && cardsContainer.children.length === 0) {
            console.log('[导航] 检测到内容为空，重新渲染');
            
            // 确保数据已加载
            if (!moduleData) {
                await loadModuleData();
            }
            
            // 恢复筛选器状态
            const statusSelect = document.getElementById('statusSelect');
            const levelSelect = document.getElementById('levelSelect');
            const searchInput = document.getElementById('searchInput');
            
            if (statusSelect) statusSelect.value = filters.status;
            if (levelSelect) levelSelect.value = filters.level;
            if (searchInput) searchInput.value = filters.searchKeyword;
            
            // 重新渲染
            renderCards();
        }
        
        lucide.createIcons();
    }
}
```

**关键原则**：
- ✅ 保存状态：所有变量、筛选条件、选中状态
- ✅ 重新加载HTML后立即恢复状态
- ✅ 检测内容丢失，自动重新渲染
- ✅ 延迟恢复选中状态（等DOM渲染完成）

